<div class="container-fluid px-0">
  <div class="row">
    <div class="col-12">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
        <div class="mb-3 mb-md-0">
          <h1 class="h3 mb-2 text-gray-800">Control de Asistencia</h1>
          <p class="mb-0 text-muted">Escanee el código QR del empleado para registrar entrada o salida</p>
        </div>
        <div class="mt-3">
          <a href="/recursos-humanos" class="btn btn-secondary mr-2"><i class="fas fa-arrow-left"></i> Volver a Recursos Humanos</a>
          <a href="/recursos-humanos/attendance/history?type=profesor" class="btn btn-info"><i class="fas fa-history"></i> Ver Historial de Profesores</a>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-7 order-2 order-lg-1">
      <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3 d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between">
          <h6 class="m-0 font-weight-bold text-primary mb-2 mb-sm-0">
            <i class="fas fa-qrcode mr-1"></i> Escaner de Código QR
          </h6>
          <div class="btn-group btn-group-sm">
            <button id="startButton" class="btn btn-success mr-2">
              <i class="fas fa-play mr-1"></i> Iniciar Escaneo
            </button>
            <button id="stopButton" class="btn btn-danger mr-2" disabled>
              <i class="fas fa-stop mr-1"></i> Detener
            </button>
            <button id="resetButton" class="btn btn-secondary">
              <i class="fas fa-sync-alt mr-1"></i> Reiniciar
            </button>
          </div>
        </div>
        <div class="card-body">
          <div id="reader" class="mb-3 mx-auto" style="width: 100%; max-width: 500px; min-height: 300px;"></div>
          
          <div class="alert alert-info bg-light-info border-0">
            <div class="d-flex flex-column flex-sm-row">
              <div class="mr-sm-3 mb-2 mb-sm-0 text-center text-sm-left">
                <i class="fas fa-info-circle fa-2x text-info"></i>
              </div>
              <div>
                <h5 class="alert-heading text-info">Instrucciones</h5>
                <p class="mb-0">Coloque el código QR del empleado frente a la cámara. El sistema registrará automáticamente la entrada o salida según corresponda.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="col-lg-5 order-1 order-lg-2 mb-4 mb-lg-0">
      <div class="card shadow mb-4 border-left-success">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-success">
            <i class="fas fa-clipboard-check mr-1"></i> Resultado del Escaneo
          </h6>
        </div>
        <div class="card-body">
          <div id="scanResult" class="text-center py-5">
            <div class="mb-3">
              <i class="fas fa-qrcode fa-4x text-muted"></i>
            </div>
            <h5 class="text-muted">Esperando escaneo...</h5>
            <p class="text-muted">El resultado del escaneo se mostrará aquí</p>
          </div>
          
          <div id="successResult" class="d-none">
            <div class="text-center mb-4">
              <div class="mb-3">
                <i class="fas fa-check-circle fa-4x text-success"></i>
              </div>
              <h4 class="text-success" id="actionType">Entrada Registrada</h4>
            </div>
            
            <div class="card bg-light mb-3">
              <div class="card-body">
                <h6 class="font-weight-bold mb-3">Datos del Empleado:</h6>
                <div class="row mb-2">
                  <div class="col-5 font-weight-bold text-muted">Cédula:</div>
                  <div class="col-7" id="employeeCedula"></div>
                </div>
                <div class="row mb-2">
                  <div class="col-5 font-weight-bold text-muted">Nombre:</div>
                  <div class="col-7" id="employeeName"></div>
                </div>
                <div class="row mb-2">
                  <div class="col-5 font-weight-bold text-muted">Hora:</div>
                  <div class="col-7" id="recordTime"></div>
                </div>
                <div class="row mb-2" id="hoursWorkedRow">
                  <div class="col-5 font-weight-bold text-muted">Horas trabajadas:</div>
                  <div class="col-7" id="hoursWorked"></div>
                </div>
              </div>
            </div>
          </div>
          
          <div id="errorResult" class="d-none">
            <div class="text-center mb-3">
              <div class="mb-3">
                <i class="fas fa-exclamation-circle fa-4x text-danger"></i>
              </div>
              <h4 class="text-danger">Error</h4>
              <p id="errorMessage" class="text-danger">Mensaje de error</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="card shadow mb-4 border-left-info">
        <div class="card-header py-3">
          <h6 class="m-0 font-weight-bold text-info">
            <i class="fas fa-clock mr-1"></i> Últimos Registros
          </h6>
        </div>
        <div class="card-body p-0">
          <div id="recentRecords">
            <div class="text-center py-4">
              <p class="text-muted">Los últimos registros se mostrarán aquí</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Incluir la librería HTML5-QRCode -->
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Variables globales
    let html5QrCode;
    const recentScans = [];
    let isScanning = false;
    
    // Elementos DOM
    const startButton = document.getElementById('startButton');
    const stopButton = document.getElementById('stopButton');
    const resetButton = document.getElementById('resetButton');
    const scanResult = document.getElementById('scanResult');
    const successResult = document.getElementById('successResult');
    const errorResult = document.getElementById('errorResult');
    const actionType = document.getElementById('actionType');
    const employeeCedula = document.getElementById('employeeCedula');
    const employeeName = document.getElementById('employeeName');
    const recordTime = document.getElementById('recordTime');
    const hoursWorkedRow = document.getElementById('hoursWorkedRow');
    const hoursWorked = document.getElementById('hoursWorked');
    const errorMessage = document.getElementById('errorMessage');
    const recentRecords = document.getElementById('recentRecords');
    
    // Inicializar el escaner QR
    function initQRScanner() {
      html5QrCode = new Html5Qrcode("reader");
      
      const qrCodeSuccessCallback = (decodedText, decodedResult) => {
        // Procesar el código QR sin detener el escaneo
        processQRCode(decodedText);
      };
      
      // Configuración adaptativa para el escaner QR
      const config = { 
        fps: 10, 
        qrbox: { width: 250, height: 250 },
        aspectRatio: 1.0,
        formatsToSupport: [ Html5QrcodeSupportedFormats.QR_CODE ],
        rememberLastUsedCamera: true
      };
      
      // Iniciar el escaneo con la cámara
      startButton.addEventListener('click', () => {
        if (!isScanning) {
          // Mostrar mensaje de carga
          scanResult.innerHTML = `
            <div class="mb-3">
              <i class="fas fa-spinner fa-spin fa-4x text-primary"></i>
            </div>
            <h5 class="text-primary">Iniciando cámara...</h5>
            <p class="text-muted">Por favor espere mientras se accede a la cámara</p>
          `;
          
          // Primero intentar con la cámara trasera (environment)
          html5QrCode.start(
            { facingMode: "environment" },
            config,
            qrCodeSuccessCallback
          ).then(() => {
            isScanning = true;
            startButton.disabled = true;
            stopButton.disabled = false;
            scanResult.innerHTML = `
              <div class="mb-3">
                <i class="fas fa-qrcode fa-4x text-success"></i>
              </div>
              <h5 class="text-success">Escaneo activo</h5>
              <p class="text-muted">Acerque el código QR a la cámara</p>
            `;
          }).catch(err => {
            console.error('Error al iniciar con cámara trasera, intentando con cualquier cámara:', err);
            
            // Si falla, intentar con cualquier cámara disponible
            html5QrCode.start(
              { facingMode: "user" }, // Intentar con cámara frontal
              config,
              qrCodeSuccessCallback
            ).then(() => {
              isScanning = true;
              startButton.disabled = true;
              stopButton.disabled = false;
              scanResult.innerHTML = `
                <div class="mb-3">
                  <i class="fas fa-qrcode fa-4x text-success"></i>
                </div>
                <h5 class="text-success">Escaneo activo</h5>
                <p class="text-muted">Acerque el código QR a la cámara</p>
              `;
            }).catch(err => {
              console.error('Error al iniciar escáner:', err);
              scanResult.innerHTML = `
                <div class="mb-3">
                  <i class="fas fa-exclamation-triangle fa-4x text-danger"></i>
                </div>
                <h5 class="text-danger">Error al iniciar la cámara</h5>
                <p class="text-muted">No se pudo acceder a la cámara. Por favor verifique los permisos e intente nuevamente.</p>
              `;
            });
          });
        }
      });
      
      // Detener el escaneo
      stopButton.addEventListener('click', () => {
        if (isScanning) {
          html5QrCode.stop().then(() => {
            isScanning = false;
            startButton.disabled = false;
            stopButton.disabled = true;
            scanResult.innerHTML = `
              <div class="mb-3">
                <i class="fas fa-qrcode fa-4x text-muted"></i>
              </div>
              <h5 class="text-muted">Escaneo detenido</h5>
              <p class="text-muted">Presione "Iniciar Escaneo" para continuar</p>
            `;
          }).catch(err => {
            console.error('Error al detener el escáner:', err);
          });
        }
      });
      
      // Reiniciar el escaneo
      resetButton.addEventListener('click', () => {
        if (isScanning) {
          html5QrCode.stop().then(() => {
            isScanning = false;
            startButton.disabled = false;
            stopButton.disabled = true;
            scanResult.innerHTML = `
              <div class="mb-3">
                <i class="fas fa-qrcode fa-4x text-muted"></i>
              </div>
              <h5 class="text-muted">Esperando escaneo...</h5>
              <p class="text-muted">El resultado del escaneo se mostrará aquí</p>
            `;
            successResult.classList.add('d-none');
            errorResult.classList.add('d-none');
            scanResult.classList.remove('d-none');
          }).catch(err => {
            console.error('Error al reiniciar el escáner:', err);
          });
        } else {
          scanResult.innerHTML = `
            <div class="mb-3">
              <i class="fas fa-qrcode fa-4x text-muted"></i>
            </div>
            <h5 class="text-muted">Esperando escaneo...</h5>
            <p class="text-muted">El resultado del escaneo se mostrará aquí</p>
          `;
          successResult.classList.add('d-none');
          errorResult.classList.add('d-none');
          scanResult.classList.remove('d-none');
        }
      });
    }
    
    // Procesar el código QR escaneado
    function processQRCode(qrData) {
      // Crear un overlay temporal para mostrar el procesamiento
      const processingOverlay = document.createElement('div');
      processingOverlay.className = 'position-absolute top-0 left-0 w-100 h-100 d-flex align-items-center justify-content-center bg-white bg-opacity-75';
      processingOverlay.style.zIndex = '1000';
      processingOverlay.innerHTML = `
        <div class="text-center">
          <div class="spinner-border text-primary mb-2" role="status">
            <span class="sr-only">Procesando...</span>
          </div>
          <p class="mb-0">Procesando código QR...</p>
        </div>
      `;
      
      // Añadir overlay al contenedor del escáner
      document.getElementById('reader').appendChild(processingOverlay);
      
      // Enviar datos al servidor para procesar
      fetch('/recursos-humanos/attendance/process-scan', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ qrData })
      })
      .then(response => response.json())
      .then(data => {
        // Eliminar overlay de procesamiento
        processingOverlay.remove();
        
        if (data.success) {
          // Mostrar resultado exitoso
          showSuccessResult(data);
          
          // Actualizar lista de registros recientes
          updateRecentRecords(data.recentRecords);
          
          // Si es una salida, detener el escáner automáticamente
          if (data.action === 'salida' && isScanning) {
            html5QrCode.stop().then(() => {
              isScanning = false;
              startButton.disabled = false;
              stopButton.disabled = true;
            }).catch(err => {
              console.error('Error al detener el escáner después de salida:', err);
            });
          }
        } else {
          // Mostrar mensaje de error
          showErrorResult(data.message);
        }
      })
      .catch(error => {
        // Eliminar overlay de procesamiento
        processingOverlay.remove();
        console.error('Error al procesar el código QR:', error);
        showErrorResult('Error de conexión. Intente nuevamente.');
      });
    }
    
    // Mostrar resultado exitoso
    function showSuccessResult(data) {
      // Actualizar el panel de resultado
      scanResult.classList.add('d-none');
      errorResult.classList.add('d-none');
      successResult.classList.remove('d-none');
      
      // Actualizar tipo de acción (entrada/salida)
      actionType.textContent = data.action === 'entrada' ? 'Entrada Registrada' : 'Salida Registrada';
      actionType.className = data.action === 'entrada' ? 'text-success' : 'text-info';
      
      // Actualizar datos del empleado
      employeeCedula.textContent = data.employee.cedula;
      employeeName.textContent = `${data.employee.nombres} ${data.employee.apellidos}`;
      recordTime.textContent = new Date(data.timestamp).toLocaleTimeString();
      
      // Mostrar horas trabajadas solo para salidas
      if (data.action === 'salida' && data.hoursWorked) {
        hoursWorked.textContent = `${data.hoursWorked} horas`;
        hoursWorkedRow.classList.remove('d-none');
      } else {
        hoursWorkedRow.classList.add('d-none');
      }
      
      // Mostrar notificación toast
      if (typeof toastr !== 'undefined') {
        toastr.success(
          `${data.action === 'entrada' ? 'Entrada' : 'Salida'} registrada correctamente para ${data.employee.nombres} ${data.employee.apellidos}`,
          'Registro Exitoso'
        );
      }
    }
    
    // Mostrar resultado de error
    function showErrorResult(message) {
      // Actualizar el panel de resultado
      errorResult.classList.remove('d-none');
      successResult.classList.add('d-none');
      scanResult.classList.add('d-none');
      
      // Actualizar mensaje de error
      errorMessage.textContent = message;
      
      // Mostrar notificación toast
      if (typeof toastr !== 'undefined') {
        toastr.error(message, 'Error de Registro');
      }
    }
    
    // Actualizar lista de registros recientes
    function updateRecentRecords(records) {
      if (!records || records.length === 0) {
        recentRecords.innerHTML = `
          <div class="text-center py-4">
            <p class="text-muted">No hay registros recientes</p>
          </div>
        `;
        return;
      }
      
      let html = `<ul class="list-group list-group-flush">`;
      
      records.forEach(record => {
        const date = new Date(record.timestamp);
        const timeStr = date.toLocaleTimeString();
        const dateStr = date.toLocaleDateString();
        
        const actionClass = record.action === 'entrada' ? 'success' : 'info';
        const actionIcon = record.action === 'entrada' ? 'sign-in-alt' : 'sign-out-alt';
        
        html += `
          <li class="list-group-item d-flex justify-content-between align-items-center p-3">
            <div>
              <div class="font-weight-bold">${record.employee.nombres} ${record.employee.apellidos}</div>
              <small class="text-muted">${dateStr} ${timeStr}</small>
            </div>
            <span class="badge badge-${actionClass} badge-pill px-3 py-2">
              <i class="fas fa-${actionIcon} mr-1"></i>
              ${record.action === 'entrada' ? 'Entrada' : 'Salida'}
            </span>
          </li>
        `;
      });
      
      html += `</ul>`;
      recentRecords.innerHTML = html;
    }
    
    // Inicializar el escaner QR al cargar la página
    initQRScanner();
  });
</script>
