<div class="container-fluid px-0">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h3 mb-2 text-gray-800">Registrar Nuevo Personal</h1>
          <p class="mb-0 text-muted">Complete el formulario para registrar un nuevo miembro del personal</p>
        </div>
        <a href="/recursos-humanos/empleados" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left mr-1"></i> Volver a la lista
        </a>
      </div>
    </div>
  </div>

  <div class="card shadow mb-4 border-left-warning">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-warning text-dark">
      <h6 class="m-0 font-weight-bold">
        <i class="fas fa-user-tie mr-1"></i> Datos del Personal
      </h6>
      <div class="small">
        <i class="fas fa-info-circle mr-1"></i> Se enviará un código QR al correo registrado
      </div>
    </div>
    
    <div class="card-body">
      <form action="/recursos-humanos/empleados/create-personal" method="POST" novalidate class="needs-validation">
        <input type="hidden" name="tipoEmpleado" value="Personal">
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="cedula" class="font-weight-bold">Cédula <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                </div>
                <input type="text" class="form-control" id="cedula" name="cedula" value="<%= typeof cedula != 'undefined' ? cedula : '' %>" placeholder="V-12345678" required>
              </div>
              <small class="form-text text-muted">Formato: V-12345678 o E-12345678</small>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="email" class="font-weight-bold">Email <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                </div>
                <input type="email" class="form-control" id="email" name="email" value="<%= typeof email != 'undefined' ? email : '' %>" placeholder="correo@ejemplo.com" required>
              </div>
              <small class="form-text text-muted">Se enviará el código QR a este correo</small>
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="nombres" class="font-weight-bold">Nombres <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-user"></i></span>
                </div>
                <input type="text" class="form-control" id="nombres" name="nombres" value="<%= typeof nombres != 'undefined' ? nombres : '' %>" placeholder="Nombres del personal" required>
              </div>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="apellidos" class="font-weight-bold">Apellidos <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-user"></i></span>
                </div>
                <input type="text" class="form-control" id="apellidos" name="apellidos" value="<%= typeof apellidos != 'undefined' ? apellidos : '' %>" placeholder="Apellidos del personal" required>
              </div>
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="cargo" class="font-weight-bold">Cargo <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-briefcase"></i></span>
                </div>
                <input type="text" class="form-control" id="cargo" name="cargo" value="<%= typeof cargo != 'undefined' ? cargo : '' %>" placeholder="Cargo del personal" required>
              </div>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="departamento" class="font-weight-bold">Departamento <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-building"></i></span>
                </div>
                <select class="form-control" id="departamento" name="departamento" required>
                  <option value="" disabled <%= typeof departamento == 'undefined' ? 'selected' : '' %>>Seleccione un departamento</option>
                  <option value="Administración" <%= typeof departamento != 'undefined' && departamento === 'Administración' ? 'selected' : '' %>>Administración</option>
                  <option value="Recursos Humanos" <%= typeof departamento != 'undefined' && departamento === 'Recursos Humanos' ? 'selected' : '' %>>Recursos Humanos</option>
                  <option value="Mantenimiento" <%= typeof departamento != 'undefined' && departamento === 'Mantenimiento' ? 'selected' : '' %>>Mantenimiento</option>
                  <option value="Seguridad" <%= typeof departamento != 'undefined' && departamento === 'Seguridad' ? 'selected' : '' %>>Seguridad</option>
                  <option value="Biblioteca" <%= typeof departamento != 'undefined' && departamento === 'Biblioteca' ? 'selected' : '' %>>Biblioteca</option>
                  <option value="Otro" <%= typeof departamento != 'undefined' && departamento === 'Otro' ? 'selected' : '' %>>Otro</option>
                </select>
              </div>
            </div>
          </div>
        </div>
        
        <div class="alert alert-warning bg-light-warning border-0 mt-4">
          <div class="d-flex">
            <div class="mr-3">
              <i class="fas fa-info-circle fa-2x text-warning"></i>
            </div>
            <div>
              <h5 class="alert-heading text-warning">Información Importante</h5>
              <p class="mb-0">Todos los campos marcados con <span class="text-danger">*</span> son obligatorios. Al registrar el personal, se generará automáticamente un código QR que será enviado al correo electrónico proporcionado.</p>
            </div>
          </div>
        </div>
        
        <hr class="my-4">
        
        <div class="text-right">
          <a href="/recursos-humanos/empleados" class="btn btn-outline-secondary mr-2">
            <i class="fas fa-times mr-1"></i> Cancelar
          </a>
          <button type="submit" class="btn btn-warning">
            <i class="fas fa-save mr-1"></i> Guardar Personal
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
