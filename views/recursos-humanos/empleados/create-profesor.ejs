<div class="container-fluid px-0">
  <div class="row">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h3 mb-2 text-gray-800">Registrar Nuevo Profesor</h1>
          <p class="mb-0 text-muted">Complete el formulario para registrar un nuevo profesor</p>
        </div>
        <a href="/recursos-humanos/empleados" class="btn btn-outline-secondary btn-sm">
          <i class="fas fa-arrow-left mr-1"></i> Volver a la lista
        </a>
      </div>
    </div>
  </div>

  <div class="card shadow mb-4 border-left-primary">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-primary text-white">
      <h6 class="m-0 font-weight-bold">
        <i class="fas fa-chalkboard-teacher mr-1"></i> Datos del Profesor
      </h6>
      <div class="small">
        <i class="fas fa-info-circle mr-1"></i> Se enviará un código QR al correo registrado
      </div>
    </div>
    
    <div class="card-body">
      <form action="/recursos-humanos/empleados/create-profesor" method="POST" novalidate class="needs-validation">
        <input type="hidden" name="tipoEmpleado" value="Profesor">
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="cedula" class="font-weight-bold">Cédula <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                </div>
                <input type="text" class="form-control" id="cedula" name="cedula" value="<%= typeof cedula != 'undefined' ? cedula : '' %>" placeholder="V-12345678" required>
              </div>
              <small class="form-text text-muted">Formato: V-12345678 o E-12345678</small>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="email" class="font-weight-bold">Email <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                </div>
                <input type="email" class="form-control" id="email" name="email" value="<%= typeof email != 'undefined' ? email : '' %>" placeholder="correo@ejemplo.com" required>
              </div>
              <small class="form-text text-muted">Se enviará el código QR a este correo</small>
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="nombres" class="font-weight-bold">Nombres <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-user"></i></span>
                </div>
                <input type="text" class="form-control" id="nombres" name="nombres" value="<%= typeof nombres != 'undefined' ? nombres : '' %>" placeholder="Nombres del profesor" required>
              </div>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="apellidos" class="font-weight-bold">Apellidos <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-user"></i></span>
                </div>
                <input type="text" class="form-control" id="apellidos" name="apellidos" value="<%= typeof apellidos != 'undefined' ? apellidos : '' %>" placeholder="Apellidos del profesor" required>
              </div>
            </div>
          </div>
        </div>
        
        <div class="row">
          <div class="col-md-6">
            <div class="form-group">
              <label for="departamento" class="font-weight-bold">Departamento <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-university"></i></span>
                </div>
                <select class="form-control" id="departamento" name="departamento" required>
                  <option value="" disabled <%= typeof departamento == 'undefined' ? 'selected' : '' %>>Seleccione un departamento</option>
                  <option value="Matemáticas" <%= typeof departamento != 'undefined' && departamento === 'Matemáticas' ? 'selected' : '' %>>Matemáticas</option>
                  <option value="Física" <%= typeof departamento != 'undefined' && departamento === 'Física' ? 'selected' : '' %>>Física</option>
                  <option value="Química" <%= typeof departamento != 'undefined' && departamento === 'Química' ? 'selected' : '' %>>Química</option>
                  <option value="Biología" <%= typeof departamento != 'undefined' && departamento === 'Biología' ? 'selected' : '' %>>Biología</option>
                  <option value="Historia" <%= typeof departamento != 'undefined' && departamento === 'Historia' ? 'selected' : '' %>>Historia</option>
                  <option value="Geografía" <%= typeof departamento != 'undefined' && departamento === 'Geografía' ? 'selected' : '' %>>Geografía</option>
                  <option value="Lengua y Literatura" <%= typeof departamento != 'undefined' && departamento === 'Lengua y Literatura' ? 'selected' : '' %>>Lengua y Literatura</option>
                  <option value="Inglés" <%= typeof departamento != 'undefined' && departamento === 'Inglés' ? 'selected' : '' %>>Inglés</option>
                  <option value="Educación Física" <%= typeof departamento != 'undefined' && departamento === 'Educación Física' ? 'selected' : '' %>>Educación Física</option>
                  <option value="Informática" <%= typeof departamento != 'undefined' && departamento === 'Informática' ? 'selected' : '' %>>Informática</option>
                  <option value="Otro" <%= typeof departamento != 'undefined' && departamento === 'Otro' ? 'selected' : '' %>>Otro</option>
                </select>
              </div>
            </div>
          </div>
          
          <div class="col-md-6">
            <div class="form-group">
              <label for="cargo" class="font-weight-bold">Cargo <span class="text-danger">*</span></label>
              <div class="input-group">
                <div class="input-group-prepend">
                  <span class="input-group-text"><i class="fas fa-briefcase"></i></span>
                </div>
                <select class="form-control" id="cargo" name="cargo" required>
                  <option value="" disabled <%= typeof cargo == 'undefined' ? 'selected' : '' %>>Seleccione un cargo</option>
                  <option value="Profesor Titular" <%= typeof cargo != 'undefined' && cargo === 'Profesor Titular' ? 'selected' : '' %>>Profesor Titular</option>
                  <option value="Profesor Asociado" <%= typeof cargo != 'undefined' && cargo === 'Profesor Asociado' ? 'selected' : '' %>>Profesor Asociado</option>
                  <option value="Profesor Asistente" <%= typeof cargo != 'undefined' && cargo === 'Profesor Asistente' ? 'selected' : '' %>>Profesor Asistente</option>
                  <option value="Profesor Instructor" <%= typeof cargo != 'undefined' && cargo === 'Profesor Instructor' ? 'selected' : '' %>>Profesor Instructor</option>
                  <option value="Profesor por Horas" <%= typeof cargo != 'undefined' && cargo === 'Profesor por Horas' ? 'selected' : '' %>>Profesor por Horas</option>
                  <option value="Otro" <%= typeof cargo != 'undefined' && cargo === 'Otro' ? 'selected' : '' %>>Otro</option>
                </select>
              </div>
            </div>
          </div>
        </div>
        
        <div class="alert alert-primary bg-light-primary border-0 mt-4">
          <div class="d-flex">
            <div class="mr-3">
              <i class="fas fa-info-circle fa-2x text-primary"></i>
            </div>
            <div>
              <h5 class="alert-heading text-primary">Información Importante</h5>
              <p class="mb-0">Todos los campos marcados con <span class="text-danger">*</span> son obligatorios. Al registrar el profesor, se generará automáticamente un código QR que será enviado al correo electrónico proporcionado.</p>
            </div>
          </div>
        </div>
        
        <hr class="my-4">
        
        <div class="text-right">
          <a href="/recursos-humanos/empleados" class="btn btn-outline-secondary mr-2">
            <i class="fas fa-times mr-1"></i> Cancelar
          </a>
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save mr-1"></i> Guardar Profesor
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
