<h1 class="mt-4">Gestión de Usuarios</h1>
<p class="lead mb-4">Administra los usuarios del sistema</p>

<div class="row">
  <div class="col-md-5">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-primary text-white py-3">
        <div class="d-flex align-items-center">
          <i class="fas fa-user-plus fa-2x mr-3"></i>
          <h5 class="mb-0 font-weight-bold">Crear Nuevo Usuario</h5>
        </div>
      </div>
      <div class="card-body p-4">
        <form action="/admin-users/create" method="POST" id="createUserForm" data-toast-success="Usuario creado exitosamente" data-toast-error="Error al crear el usuario" class="needs-validation" novalidate>
          <div class="form-group">
            <label for="name" class="font-weight-bold"><i class="fas fa-user text-primary mr-2"></i>Nombre Completo</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-user"></i></span>
              </div>
              <input
                type="text"
                id="name"
                name="name"
                class="form-control"
                placeholder="Ingresa el nombre completo"
                required
                data-toast-empty="El nombre es obligatorio"
              />
              <div class="invalid-feedback">El nombre es obligatorio</div>
            </div>
          </div>
          <div class="form-group">
            <label for="username" class="font-weight-bold"><i class="fas fa-user-tag text-primary mr-2"></i>Nombre de Usuario</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-user-tag"></i></span>
              </div>
              <input
                type="text"
                id="username"
                name="username"
                class="form-control"
                placeholder="Ingresa el nombre de usuario"
                required
                data-toast-empty="El nombre de usuario es obligatorio"
              />
              <div class="invalid-feedback">El nombre de usuario es obligatorio</div>
            </div>
          </div>
          <div class="form-group">
            <label for="email" class="font-weight-bold"><i class="fas fa-envelope text-primary mr-2"></i>Correo Electrónico</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
              </div>
              <input
                type="email"
                id="email"
                name="email"
                class="form-control"
                placeholder="Ingresa el correo electrónico"
                required
                data-toast-empty="El correo electrónico es obligatorio"
              />
              <div class="invalid-feedback">Ingresa un correo electrónico válido</div>
            </div>
          </div>
          <div class="form-group">
            <label for="password" class="font-weight-bold"><i class="fas fa-lock text-primary mr-2"></i>Contraseña</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
              </div>
              <input
                type="password"
                id="password"
                name="password"
                class="form-control"
                placeholder="Ingresa la contraseña"
                required
                minlength="6"
                data-toast-empty="La contraseña es obligatoria"
              />
              <div class="invalid-feedback">La contraseña debe tener al menos 6 caracteres</div>
            </div>
          </div>
          <div class="form-group">
            <label for="password2" class="font-weight-bold"><i class="fas fa-lock text-primary mr-2"></i>Confirmar Contraseña</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-check-double"></i></span>
              </div>
              <input
                type="password"
                id="password2"
                name="password2"
                class="form-control"
                placeholder="Confirma la contraseña"
                required
                data-toast-empty="Debes confirmar la contraseña"
              />
              <div class="invalid-feedback">Las contraseñas deben coincidir</div>
            </div>
          </div>
          <div class="form-group">
            <label for="role" class="font-weight-bold"><i class="fas fa-user-shield text-primary mr-2"></i>Rol</label>
            <div class="input-group">
              <div class="input-group-prepend">
                <span class="input-group-text"><i class="fas fa-user-shield"></i></span>
              </div>
              <select class="form-control" id="role" name="role" required data-toast-empty="Debes seleccionar un rol">
                <option value="" disabled selected>Selecciona un rol</option>
                <option value="admin">Administrador</option>
                <option value="recursos_humanos">Recursos Humanos</option>
                <option value="caja">Caja</option>
                <option value="control_estudio">Control de Estudio</option>
              </select>
              <div class="invalid-feedback">Debes seleccionar un rol para el usuario</div>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block py-2 mt-4" id="submitBtn">
            <i class="fas fa-user-plus mr-2"></i> Crear Usuario
          </button>
          <div class="mt-3" id="formFeedback"></div>
        </form>
      </div>
    </div>
  </div>
  
  <div class="col-md-7">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-info text-white py-3">
        <div class="d-flex align-items-center">
          <i class="fas fa-users fa-2x mr-3"></i>
          <h5 class="mb-0 font-weight-bold">Usuarios Registrados</h5>
        </div>
      </div>
      <div class="card-body p-4">
        <div class="mb-3">
          <div class="input-group">
            <div class="input-group-prepend">
              <span class="input-group-text"><i class="fas fa-search"></i></span>
            </div>
            <input type="text" id="searchUsers" class="form-control" placeholder="Buscar usuarios..." aria-label="Buscar usuarios">
          </div>
        </div>
        <div class="table-responsive">
          <table class="table table-hover shadow-sm">
            <thead class="bg-light">
              <tr>
                <th class="font-weight-bold text-primary"><i class="fas fa-user mr-2"></i>Nombre</th>
                <th class="font-weight-bold text-primary"><i class="fas fa-user-tag mr-2"></i>Usuario</th>
                <th class="font-weight-bold text-primary"><i class="fas fa-envelope mr-2"></i>Email</th>
                <th class="font-weight-bold text-primary"><i class="fas fa-user-shield mr-2"></i>Rol</th>
                <th class="font-weight-bold text-primary"><i class="fas fa-calendar-alt mr-2"></i>Fecha Registro</th>
                <th class="font-weight-bold text-primary"><i class="fas fa-cogs mr-2"></i>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% if(typeof users != 'undefined' && users.length > 0) { %>
                <% users.forEach(function(user) { %>
                  <tr class="border-bottom">
                    <td class="align-middle font-weight-bold"><%= user.name %></td>
                    <td class="align-middle"><%= user.username %></td>
                    <td class="align-middle"><%= user.email %></td>
                    <td class="align-middle">
                      <% let badgeClass = 'badge-info'; %>
                      <% let roleName = 'Desconocido'; %>
                      <% let roleIcon = 'fa-question-circle'; %>
                      
                      <% if(user.role === 'admin') { %>
                        <% badgeClass = 'badge-danger'; %>
                        <% roleName = 'Administrador'; %>
                        <% roleIcon = 'fa-user-shield'; %>
                      <% } else if(user.role === 'recursos_humanos') { %>
                        <% badgeClass = 'badge-warning'; %>
                        <% roleName = 'Recursos Humanos'; %>
                        <% roleIcon = 'fa-users-cog'; %>
                      <% } else if(user.role === 'caja') { %>
                        <% badgeClass = 'badge-info'; %>
                        <% roleName = 'Caja'; %>
                        <% roleIcon = 'fa-cash-register'; %>
                      <% } else if(user.role === 'control_estudio') { %>
                        <% badgeClass = 'badge-success'; %>
                        <% roleName = 'Control de Estudio'; %>
                        <% roleIcon = 'fa-graduation-cap'; %>
                      <% } %>
                      
                      <span class="badge badge-pill <%= badgeClass %> px-3 py-2">
                        <i class="fas <%= roleIcon %> mr-1"></i> <%= roleName %>
                      </span>
                    </td>
                    <td class="align-middle">
                      <i class="far fa-calendar-alt text-muted mr-1"></i> <%= new Date(user.date).toLocaleDateString() %>
                    </td>
                    <td class="align-middle">
                      <div class="btn-group" role="group">
                        <a href="/admin-users/edit/<%= user._id %>" class="btn btn-warning btn-sm" title="Editar">
                          <i class="fas fa-edit"></i>
                        </a>
                        <button type="button" class="btn btn-danger btn-sm delete-user" data-toggle="modal" data-target="#deleteUserModal" data-id="<%= user._id %>" data-name="<%= user.name %>" data-username="<%= user.username %>" title="Eliminar">
                          <i class="fas fa-trash"></i>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-5">
                    <div class="empty-state">
                      <i class="fas fa-users fa-4x text-muted mb-3"></i>
                      <h5 class="text-muted">No hay usuarios registrados</h5>
                      <p class="text-muted">Utilice el formulario para crear nuevos usuarios</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de confirmación para eliminar usuario -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" role="dialog" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title" id="deleteUserModalLabel"><i class="fas fa-exclamation-triangle"></i> Confirmar eliminación</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <p>¿Estás seguro de que deseas eliminar al usuario <strong id="deleteUserName"></strong>?</p>
        <p class="text-danger"><i class="fas fa-exclamation-circle"></i> Esta acción no se puede deshacer.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
        <a href="#" id="confirmDeleteBtn" class="btn btn-danger">Eliminar Usuario</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Script para manejar la eliminación de usuarios con modal y la búsqueda
  document.addEventListener('DOMContentLoaded', function() {
    // Funcionalidad de búsqueda para la tabla de usuarios
    const searchInput = document.getElementById('searchUsers');
    const table = document.querySelector('.table-responsive table');
    const rows = table.getElementsByTagName('tbody')[0].getElementsByTagName('tr');
    
    searchInput.addEventListener('keyup', function() {
      const searchTerm = searchInput.value.toLowerCase();
      
      for (let i = 0; i < rows.length; i++) {
        const row = rows[i];
        if (row.cells.length <= 1) continue; // Ignorar fila de 'No hay usuarios'
        
        const name = row.cells[0].textContent.toLowerCase();
        const username = row.cells[1].textContent.toLowerCase();
        const email = row.cells[2].textContent.toLowerCase();
        const role = row.cells[3].textContent.toLowerCase();
        
        if (name.includes(searchTerm) || 
            username.includes(searchTerm) || 
            email.includes(searchTerm) || 
            role.includes(searchTerm)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      }
    });

    // Cuando se hace clic en el botón de eliminar
    $('.delete-user').on('click', function() {
      // Obtener datos del usuario a eliminar
      var userId = $(this).data('id');
      var userName = $(this).data('name');
      var username = $(this).data('username');
      
      // Actualizar el modal con los datos del usuario
      $('#deleteUserName').text(userName + ' (' + username + ')');
      $('#confirmDeleteBtn').attr('href', '/admin-users/delete/' + userId);
      
      // Mostrar notificación toast
      if (typeof showWarningToast === 'function') {
        showWarningToast('¿Estás seguro de eliminar a ' + userName + '?');
      }
    });
    
    // Cuando se confirma la eliminación
    $('#confirmDeleteBtn').on('click', function() {
      if (typeof showInfoToast === 'function') {
        showInfoToast('Procesando eliminación...');
      }
    });
  });
</script>

<div class="mt-3">
  <a href="/admin-panel" class="btn btn-secondary mr-2"><i class="fas fa-arrow-left"></i> Volver al Panel de Administración</a>
</div>
